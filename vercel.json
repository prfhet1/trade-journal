{
  "functions": {
    "api/webhook.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/deskbot.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/stats-cron.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
